# ============================================================
# Database
# ============================================================
# Prisma runtime connection.
#
# Local Docker:
#   postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?schema=public
#   Example:
#   postgresql://postgres:postgres@localhost:5432/personal_finance?schema=public
#
# Supabase:
#   Copy the connection string from:
#   Supabase Dashboard > Project Settings > Database > Connect
#
# For a deployed Backend, use the Supabase Session Pooler connection
# if the hosting provider cannot connect to Supabase through IPv6.
DATABASE_URL=postgresql://<SUPABASE_USER>:<SUPABASE_PASSWORD>@<SUPABASE_HOST>:<SUPABASE_PORT>/postgres?schema=public

# Direct connection used by Prisma migrations and database administration.
# Copy this from the Direct connection section in:
# Supabase Dashboard > Project Settings > Database > Connect
#
# Local Docker uses the same connection as DATABASE_URL:
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/personal_finance?schema=public
DIRECT_URL=postgresql://<SUPABASE_USER>:<SUPABASE_PASSWORD>@<SUPABASE_DIRECT_HOST>:5432/postgres?schema=public

# ============================================================
# Server
# ============================================================
# Port used by the NestJS Backend.
# Render usually provides PORT automatically; keep 3001 for local Docker.
PORT=3001

# ============================================================
# Authentication
# ============================================================
# Secret used to sign and verify JWT access tokens.
# Generate a different long random value for every environment.
# Never use the example value in production and never commit the real value.
JWT_SECRET=<LONG_RANDOM_JWT_SECRET>
